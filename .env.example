APP_NAME=Freight Back Office OS API
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=true

SECRET_KEY=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60

DATABASE_URL_OVERRIDE=postgresql+psycopg://postgres:postgres@localhost:5432/freight_back_office_os
REDIS_URL_OVERRIDE=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CORS_ALLOWED_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:80","http://127.0.0.1:80","http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

STORAGE_LOCAL_ROOT=data/sandbox/uploaded-docs

LOG_LEVEL=INFO
LOG_JSON=true

AI_ENABLED=false
WHATSAPP_ENABLED=false
EMAIL_ENABLED=false
EMAIL_PROVIDER=none
DEFAULT_FROM_EMAIL=no-reply@freightbackoffice.local
WEB_APP_BASE_URL=http://localhost
EMAIL_DEV_ALLOW_TOKEN_RESPONSE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
BILLING_ENABLED=false
NEXT_PUBLIC_STRIPE_STARTER_LINK=https://buy.stripe.com/fZu8wP1HIc6m48R0PA7Vm00
NEXT_PUBLIC_STRIPE_GROWTH_LINK=https://buy.stripe.com/fZu7sL1HI7Q6fRz7dY7Vm01
NEXT_PUBLIC_ENTERPRISE_CONTACT=mailto:mermerbrands@gmail.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_VERSION_PREFIX=/api/v1
